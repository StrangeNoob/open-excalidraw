{
  "name": "@open-excalidraw/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@open-excalidraw/contracts": "workspace:*",
    "@open-excalidraw/database": "workspace:*",
    "@open-excalidraw/mail": "workspace:*",
    "@open-excalidraw/storage": "workspace:*",
    "better-auth": "1.6.23",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "file-type": "22.0.1",
    "helmet": "8.2.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "socket.io": "4.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "testcontainers": "12.0.4",
    "tsx": "4.23.0"
  }
}
