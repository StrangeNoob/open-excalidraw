{
  "name": "open-excalidraw",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "concurrently -n web,server -c cyan,magenta \"pnpm --filter @open-excalidraw/web dev\" \"pnpm --filter @open-excalidraw/server dev\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "test:e2e": "pnpm --filter @open-excalidraw/web test:e2e",
    "test:integration": "pnpm -r --if-present test:integration",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
