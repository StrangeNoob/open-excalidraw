APP_BASE_URL=http://localhost:3000
APP_PORT=3000
# Comma-separated additional browser origins allowed for Socket.IO upgrades.
# Local development automatically allows http://localhost:5173.
SOCKET_ALLOWED_ORIGINS=
# Set to true only when a reverse proxy that overwrites X-Forwarded-For and
# X-Real-IP sits in front (the bundled Caddy profile does). Left false, those
# headers are discarded and the client IP comes from the socket, so a directly
# exposed port cannot have its per-IP sign-in throttling bypassed by a spoofed
# header. Set it to true behind a proxy or every client shares one rate limit.
TRUST_PROXY=false
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Session lifetime in seconds (sliding expiry). Defaults to 30 days.
SESSION_TTL_SECONDS=2592000
ADMIN_RESET_TOKEN=replace-with-another-32-random-characters
# Comma-separated emails allowed to use the admin page (user list, disable,
# delete, instance counts). Leave blank to disable admin access entirely.
# The admin's account email must be VERIFIED to unlock access: verify via the
# SMTP verification email, or sign in through Google/GitHub/OIDC. With SMTP
# disabled and password-only auth, admin access requires an OAuth/OIDC account.
ADMIN_EMAILS=
# Set to "true" to block all new account registration (email/password and
# OAuth/OIDC). Existing users can still sign in. Defaults to false.
DISABLE_SIGNUPS=false
POSTGRES_DB=open_excalidraw
POSTGRES_USER=open_excalidraw
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Optional override for an external/managed database. URL-encode credentials.
# DATABASE_URL=postgresql://user:password@host:5432/database
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/data/assets
# Retention/cleanup cadence; defaults to six hours.
MAINTENANCE_INTERVAL_MS=21600000

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional generic OIDC SSO (Keycloak, Authentik, Authelia, ...).
# OIDC_ISSUER_URL accepts the issuer base URL or the full discovery URL.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Button label, e.g. "Keycloak"; defaults to "SSO".
OIDC_PROVIDER_NAME=

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Open Excalidraw <noreply@example.com>

# S3-compatible object storage. Set STORAGE_DRIVER=s3 to store assets in any
# S3-compatible bucket instead of the local volume (STORAGE_LOCAL_PATH is then
# unused). Endpoint examples:
#   AWS S3:              omit S3_ENDPOINT, set S3_REGION
#   Cloudflare R2:       S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   MinIO:               S3_ENDPOINT=http://localhost:9000 and S3_FORCE_PATH_STYLE=true
#   Backblaze B2:        S3_ENDPOINT=https://s3.<region>.backblazeb2.com
#   DigitalOcean Spaces: S3_ENDPOINT=https://<region>.digitaloceanspaces.com
#   Wasabi:              S3_ENDPOINT=https://s3.<region>.wasabisys.com
# STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
